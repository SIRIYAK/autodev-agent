{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "vscode", "mocha"]
  },
  "include": [
    "extension.ts",
    "agents/**/*.ts",
    "llm/**/*.ts",
    "context/**/*.ts",
    "tools/**/*.ts",
    "ui/**/*.ts",
    "tests/**/*.ts"
  ]
}
